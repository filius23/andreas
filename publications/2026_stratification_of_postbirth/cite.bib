  title = {Stratification of Post-Birth Labour Supply in a High- and Low- Maternal Employment Regime},
  author = {Andreas Filser and Pascal Achard and Corinna Frodermann and Dana M{\"u}ller and Sander Wagner},
  year = {2026},
  month = {feb},
  journal = {Research in Social Stratification and Mobility},
